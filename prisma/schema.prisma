generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String?
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VerificationCode {
  id          String                  @id @default(cuid())
  reason      VerificationCodeReasons @default(EMAIL_VERIFICATION)
  code        Int
  codeExpires DateTime
  email       String
  createdAt   DateTime                @default(now())
  user        User                    @relation(fields: [email], references: [email], onDelete: Cascade)
}

model User {
  id                     String             @id @default(cuid())
  role                   Role               @default(USER)
  email                  String?            @unique
  username               String?            @unique
  firstname              String?
  lastname               String?
  name                   String?
  password               String?
  emailVerified          DateTime?
  image                  String?
  bio                    String?
  points                 Int                @default(0)
  currentStreak          Int                @default(0)
  lastDailyRewardDate    DateTime?
  plan                   PlanType           @default(FREE)
  dailyTasksCreatedCount Int                @default(0)
  lastTaskCreatedAt      DateTime?
  currentPeriodEnd       DateTime?
  accounts               Account[]
  orders                 Order[]
  payments               Payment[]
  pointTransactions      PointTransaction[]
  sessions               Session[]
  supportTickets         SupportTicket[]
  createdTasks           Task[]
  taskCompletions        TaskCompletion[]
  verificationCodes      VerificationCode[]
}

model RewardCampaign {
  id                String             @id @default(cuid())
  name              String             @unique
  isActive          Boolean            @default(true)
  title             String
  description       String?
  claimedCount      Int                @default(0)
  maxLimit          Int                @default(1000)
  rewardAmount      Int
  rewardType        RewardType         @default(POINTS)
  requiresNewUser   Boolean            @default(false)
  maxAccountAgeDays Int?
  startDate         DateTime?
  endDate           DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  claims            PointTransaction[]
}

model PointTransaction {
  id               String            @id @default(cuid())
  userId           String
  amount           Int
  type             TransactionType
  source           TransactionSource
  createdAt        DateTime          @default(now())
  rewardCampaignId String?
  taskCompletionId String?           @unique
  rewardCampaign   RewardCampaign?   @relation(fields: [rewardCampaignId], references: [id])
  taskCompletion   TaskCompletion?   @relation(fields: [taskCompletionId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id                 String           @id @default(cuid())
  title              String
  description        String?
  quantity           Int
  amount             Int
  platform           TaskPlatform
  userId             String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  allowsMultiAccount Boolean          @default(false)
  link               String
  expiresAt          DateTime?        @default(now())
  creator            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions        TaskCompletion[]
}

model TaskCompletion {
  id              String               @id @default(cuid())
  userId          String
  taskId          String
  completionProof String
  status          TaskCompletionStatus @default(PENDING)
  createdAt       DateTime             @default(now())
  pointReward     PointTransaction?
  task            Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId, completionProof])
}

model Service {
  id           String       @id @default(cuid())
  code         String       @unique
  name         String
  platform     TaskPlatform
  pricePerUnit Int
  minQuantity  Int
  maxQuantity  Int
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  orders       Order[]
}

model Order {
  id                String      @id @default(cuid())
  serviceId         String
  quantity          Int
  data              String?
  link              String
  totalPrice        Int
  status            OrderStatus @default(PENDING)
  deliveredQuantity Int         @default(0)
  userId            String
  paymentId         String      @unique
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  payment           Payment     @relation(fields: [paymentId], references: [id])
  service           Service     @relation(fields: [serviceId], references: [id])
  user              User        @relation(fields: [userId], references: [id])
}

model Payment {
  id                     String          @id @default(cuid())
  userId                 String
  provider               PaymentProvider
  status                 PaymentStatus   @default(PENDING)
  amountFiat             Float?
  currencyFiat           String?
  amountCrypto           Float?
  currencyCrypto         String?
  cryptoAddress          String?
  providerRef            String?
  createdAt              DateTime        @default(now())
  confirmedAt            DateTime?
  expirationEstimateDate DateTime?
  network                String?
  txHash                 String?         @unique
  validUntil             DateTime?
  order                  Order?
  user                   User            @relation(fields: [userId], references: [id])
}

model SupportTicket {
  id        String              @id @default(cuid())
  userId    String?
  email     String
  subject   String
  message   String
  status    SupportTicketStatus @default(PENDING)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User?               @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  EARN
  SPEND
}

enum TransactionSource {
  CAMPAIGN
  DAILY_REWARD
  TASK_COMPLETION
  PURCHASE
  ADMIN_ADJUST
  REFERRAL_BONUS
  TASK_FUNDING
}

enum RewardType {
  POINTS
}

enum TaskPlatform {
  FACEBOOK
  INSTAGRAM
  YOUTUBE
  X
  TIKTOK
}

enum PlanType {
  FREE
  PREMIUM
  PRO
}

enum TaskCompletionStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  CANCELED
  PARTIAL
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  CRYPTO
  ADMIN
  STARS
}

enum SupportTicketStatus {
  PENDING
  OPEN
  CLOSED
}

enum VerificationCodeReasons {
  EMAIL_VERIFICATION
}
